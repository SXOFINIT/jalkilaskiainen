
<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jälkilaskiainen Basic</title>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <style>
    :root{
      --bg:#f4f7fb; --card:#ffffff; --ink:#1f2937; --muted:#6b7280; --line:#d9e2ec;
      --accent:#0f766e; --soft:#f8fafc; --soft2:#fbfdff;
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:var(--bg);color:var(--ink);font-size:12px}
    .wrap{max-width:1560px;margin:0 auto;padding:14px}
    .hero{display:flex;gap:10px;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;margin-bottom:10px}
    h1{margin:0 0 2px;font-size:22px}
    .sub{color:var(--muted);max-width:1100px;line-height:1.35;font-size:12px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:12px;box-shadow:0 2px 7px rgba(0,0,0,.03)}
    .toolbar{padding:12px;display:grid;grid-template-columns:1.35fr .8fr .8fr auto auto;gap:8px;align-items:end}
    label{display:block;font-size:11px;color:var(--muted);margin-bottom:4px}
    input[type=file],select,input[type=number]{
      width:100%;padding:8px 9px;border:1px solid var(--line);border-radius:9px;background:#fff;font-size:12px;
    }
    button{padding:9px 12px;border:none;border-radius:9px;background:var(--accent);color:#fff;font-weight:600;cursor:pointer;font-size:12px}
    button.secondary{background:#e6eef7;color:#17324d}
    button:disabled{opacity:.6;cursor:not-allowed}
    .error,.info{display:none;margin-top:9px;padding:10px 12px;border-radius:11px;font-size:12px}
    .error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .info{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
    .summary{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin:10px 0}
    .metric{padding:10px 12px}
    .metric .k{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em}
    .metric .v{font-size:18px;font-weight:700;margin-top:3px}
    .metric .s{margin-top:3px;color:var(--muted);font-size:11px}
    .days{display:grid;gap:8px}
    .day{overflow:hidden}
    .day-head{display:grid;grid-template-columns:auto minmax(210px,1.1fr) repeat(5,minmax(135px,1fr));gap:8px;align-items:stretch;padding:10px 12px}
    .day-head:hover{background:#fbfdff}
    .day-date{display:flex;flex-direction:column;justify-content:center;gap:4px;padding-right:6px}
    .day-metric{display:grid;grid-template-rows:auto auto;gap:0;border:1px solid var(--line);border-radius:10px;background:linear-gradient(180deg,#ffffff 0%, #f8fbff 100%);overflow:hidden}
    .metric-top,.metric-bottom{padding:6px 9px;display:flex;flex-direction:column;justify-content:center;min-height:32px}
    .metric-bottom{border-top:1px solid #e9eff6;background:#fbfdff}
    .metric-label{font-size:10px;color:var(--muted);line-height:1.15}
    .metric-value{margin-top:2px;font-weight:700}
    .mono{font-variant-numeric:tabular-nums}
    .toggle{width:28px;height:28px;border-radius:8px;background:#ecfeff;color:#155e75;font-size:17px;line-height:1;padding:0;align-self:center}
    .day-body{display:none;border-top:1px solid var(--line);padding:0 12px 12px}
    .day.open .day-body{display:block}
    .day-sales{
      display:grid;grid-template-columns:repeat(6,minmax(100px,1fr));
      gap:3px;padding:4px 8px;border-top:1px solid var(--line);background:#fcfdff
    }
    .sales-field{display:flex;flex-direction:column;gap:2px}
    .sales-field .sales-label{font-size:8px;color:var(--muted);line-height:1.05}
    .sales-field input{padding:3px 5px;font-size:10px;border-radius:7px;background:#fff}
    .day-tools{display:grid;grid-template-columns:repeat(4,minmax(120px,1fr));gap:8px;padding:8px 0 6px}
    .mini-card{padding:8px;border:1px solid var(--line);border-radius:10px;background:#fafcff}
    .mini-card .label{font-size:10px;color:var(--muted);margin-bottom:3px}
    .mini-card .value{font-weight:700}
    table{width:100%;border-collapse:collapse;font-size:11px}
    th,td{padding:6px 6px;border-bottom:1px solid #edf2f7;text-align:left;vertical-align:top}
    th{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.03em;white-space:nowrap}
    tr:last-child td{border-bottom:none}
    .menu-row{background:#fbfdff}
    .menu-name{font-weight:700}
    .menu-sub{color:var(--muted);font-size:10px}
    .indent{padding-left:18px}
    .small{font-size:10px;color:var(--muted)}
    .right{text-align:right}
    .muted{color:var(--muted)}
    .pill{display:inline-block;padding:2px 6px;border-radius:999px;background:#eef6ff;color:#305d8c;font-size:10px;width:max-content}
    .footer-note{margin-top:10px;color:var(--muted);font-size:10px;line-height:1.35}
    @media (max-width:1280px){
      .summary{grid-template-columns:repeat(3,1fr)}
      .toolbar{grid-template-columns:1fr 1fr}
      .day-head{grid-template-columns:auto 1fr repeat(3,minmax(135px,1fr))}
      .hide-lg{display:none}
      .day-sales{grid-template-columns:repeat(6,1fr)}
    }
    @media (max-width:900px){
      .summary{grid-template-columns:repeat(2,1fr)}
      .day-tools{grid-template-columns:1fr 1fr}
      .hide-md{display:none}
      .day-sales{grid-template-columns:repeat(3,1fr)}
    }
    @media (max-width:700px){
      .summary{grid-template-columns:1fr}
      .toolbar{grid-template-columns:1fr}
      .day-head{grid-template-columns:auto 1fr}
      .hide-sm{display:none}
      .day-tools{grid-template-columns:1fr}
      .day-sales{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
<div class="wrap">
  <div class="hero">
    <div>
      <h1>Jälkilaskiainen Basic</h1>
      <div class="sub">
        Lukee sekä englannin- että suomenkielisen lähdedatan. Komponenttitason tiedoissa suomenkielinen
        <strong>ainesosa</strong> käsitellään samana tasona kuin englanninkielinen <strong>component</strong>.
        Yhteenveto näyttää mukana olevilta päiviltä keskiarvot: kustannus / suunniteltu annos, kustannus / tuotettu annos
        ja kustannus / myyty annos.
      </div>
    </div>
  </div>

  <div class="card toolbar">
    <div>
      <label for="fileInput">Lähde-Excel</label>
      <input id="fileInput" type="file" accept=".xlsx,.xls" />
    </div>
    <div>
      <label for="decimalMode">Desimaalierotin tekstimuotoisille luvuille</label>
      <select id="decimalMode">
        <option value="auto">Automaattinen</option>
        <option value="comma">Pilkku (,)</option>
        <option value="dot">Piste (.)</option>
      </select>
    </div>
    <div>
      <label for="dayFilter">Näytä päivä</label>
      <select id="dayFilter"><option value="">Kaikki päivät</option></select>
    </div>
    <div><label>&nbsp;</label><button id="parseBtn">Lue Excel</button></div>
    <div><label>&nbsp;</label><button id="exportBtn" class="secondary" disabled>Vie yhteenveto Exceliin</button></div>
  </div>

  <div id="errorBox" class="error"></div>
  <div id="infoBox" class="info"></div>
  <div id="summary" class="summary" style="display:none"></div>
  <div id="days" class="days"></div>
  <div class="footer-note">
    Huom: jos lähdetiedosto sisältää menu- ja ainesosa-/component-rivit, päivä avautuu menu- ja ainesosatasolle.
    Jos tiedostossa on vain päiväyhteenveto, plussan takana näytetään päiväkohtainen yhteenveto.
  </div>
</div>

<script>
(() => {
  const state = { workbookData:null, parsed:null, sourceType:'' };
  const el = (id) => document.getElementById(id);

  function showError(msg){ const box = el('errorBox'); box.style.display='block'; box.textContent=msg; }
  function clearError(){ const box = el('errorBox'); box.style.display='none'; box.textContent=''; }
  function showInfo(msg){ const box = el('infoBox'); box.style.display='block'; box.textContent=msg; }
  function clearInfo(){ const box = el('infoBox'); box.style.display='none'; box.textContent=''; }

  function normalizeText(v){ return v===undefined || v===null ? '' : String(v).replace(/\u00a0/g,' ').trim(); }
  function low(v){ return normalizeText(v).toLowerCase(); }
  function hasAny(text, arr){ const s = low(text); return arr.some(x => s === x || s.includes(x)); }

  function parseNumber(value, mode='auto'){
    if (typeof value === 'number') return Number.isFinite(value) ? value : 0;
    if (value === null || value === undefined) return 0;
    let s = String(value).replace(/\u00a0/g,' ').trim();
    if (!s) return 0;
    s = s.replace(/\s/g,'');
    const hasComma = s.includes(',');
    const hasDot = s.includes('.');
    if (mode === 'comma') s = s.replace(/\./g,'').replace(',', '.');
    else if (mode === 'dot') s = s.replace(/,/g,'');
    else {
      if (hasComma && hasDot) {
        if (s.lastIndexOf(',') > s.lastIndexOf('.')) s = s.replace(/\./g,'').replace(',', '.');
        else s = s.replace(/,/g,'');
      } else if (hasComma && !hasDot) s = s.replace(',', '.');
    }
    const n = Number(s);
    return Number.isFinite(n) ? n : 0;
  }

  function excelSerialToDate(serial){
    if (typeof serial !== 'number' || !Number.isFinite(serial)) return '';
    const utc_days = Math.floor(serial - 25569);
    const utc_value = utc_days * 86400;
    const date_info = new Date(utc_value * 1000);
    const fractional_day = serial - Math.floor(serial) + 0.0000001;
    let total_seconds = Math.floor(86400 * fractional_day);
    const seconds = total_seconds % 60;
    total_seconds -= seconds;
    const hours = Math.floor(total_seconds / 3600);
    const minutes = Math.floor((total_seconds - hours * 3600) / 60);
    const d = new Date(Date.UTC(date_info.getUTCFullYear(), date_info.getUTCMonth(), date_info.getUTCDate(), hours, minutes, seconds));
    const dd = String(d.getUTCDate()).padStart(2,'0');
    const mm = String(d.getUTCMonth()+1).padStart(2,'0');
    const yyyy = d.getUTCFullYear();
    return `${dd}.${mm}.${yyyy}`;
  }
  function looksLikeDateString(v){ return /^(\d{1,2})[./-](\d{1,2})[./-](\d{2,4})$/.test(normalizeText(v)); }
  function toDisplayDate(v){
    if (typeof v === 'number') return excelSerialToDate(v);
    const s = normalizeText(v);
    if (!looksLikeDateString(s)) return s;
    const m = s.match(/^(\d{1,2})[./-](\d{1,2})[./-](\d{2,4})$/);
    let a = parseInt(m[1],10), b = parseInt(m[2],10), y = parseInt(m[3].length===2 ? '20'+m[3] : m[3],10);
    let dd, mm;
    if (a > 12 && b <= 12) { dd = a; mm = b; }
    else if (b > 12 && a <= 12) { dd = b; mm = a; }
    else { dd = a; mm = b; }
    return `${String(dd).padStart(2,'0')}.${String(mm).padStart(2,'0')}.${y}`;
  }

  const MENU_LABELS = ['menu','ruokalista'];
  const COMPONENT_LABELS = ['component','ainesosa','ingredient'];
  const PLANNED_LABELS = ['planned','suunnit.','suunniteltu','suunn'];
  const PRODUCED_LABELS = ['produced','valmist.','valmistettu','tuotettu','valmist'];

  function detectSourceType(rows){
    const flat = rows.slice(0,80).flat().map(v => low(v)).filter(Boolean);
    const hasDateTemplate = flat.includes('date') || flat.includes('pvm');
    const hasMenu = flat.some(v => MENU_LABELS.includes(v));
    const hasComponent = flat.some(v => COMPONENT_LABELS.includes(v));
    if (hasMenu || hasComponent) return 'detail';
    if (hasDateTemplate) return 'summary';
    return 'detail';
  }

  function isDateRow(row){
    const c0 = row[0], c1 = normalizeText(row[1]);
    const dateCandidate = (typeof c0 === 'number' && c0 > 40000 && c0 < 60000) || looksLikeDateString(c0);
    if (!dateCandidate || !c1) return false;
    const l1 = low(c1);
    return !(MENU_LABELS.includes(l1) || COMPONENT_LABELS.includes(l1));
  }
  function isMenuHeaderRow(row){ return MENU_LABELS.includes(low(row[1])); }
  function isComponentHeaderRow(row){ return COMPONENT_LABELS.includes(low(row[1])); }
  function isModeMarkerRow(row){
    const c3 = low(row[3]), c5 = low(row[5]);
    return PLANNED_LABELS.some(x=>c3===x) || PRODUCED_LABELS.some(x=>c5===x);
  }
  function isMenuRow(row){
    const c0 = normalizeText(row[0]), c1 = normalizeText(row[1]), c2 = normalizeText(row[2]);
    if (c0 || !c1) return false;
    const l1 = low(c1);
    if (MENU_LABELS.includes(l1) || COMPONENT_LABELS.includes(l1)) return false;
    if (l1.includes('cost center') || l1.includes('kustannuspaikka') || l1.includes('time period') || l1.includes('aikajakso')) return false;
    if (c2 !== '') return false;
    const n3 = parseNumber(row[3]), n5 = parseNumber(row[5]), n4=parseNumber(row[4]), n6=parseNumber(row[6]);
    return (n3>0 || n5>0 || n4>0 || n6>0);
  }
  function isComponentRow(row){
    const c0 = normalizeText(row[0]), c1 = normalizeText(row[1]), c2 = normalizeText(row[2]);
    if (c0 || !c1 || c2==='') return false;
    const l1 = low(c1);
    if (MENU_LABELS.includes(l1) || COMPONENT_LABELS.includes(l1)) return false;
    return true;
  }

  function salesKey(day){ return `jbasic_sales_${day.dateDisplay}__${day.template}`; }
  function getSales(day){
    try{
      const raw = localStorage.getItem(salesKey(day));
      const parsed = raw ? JSON.parse(raw) : {};
      return {
        soldLunchQty: Number(parsed.soldLunchQty) || 0,
        lunchSalesEur: Number(parsed.lunchSalesEur) || 0,
        cafeSalesEur: Number(parsed.cafeSalesEur) || 0,
        cateringOrdersEur: Number(parsed.cateringOrdersEur) || 0,
        themesEur: Number(parsed.themesEur) || 0,
        additionalSalesEur: Number(parsed.additionalSalesEur) || 0
      };
    } catch(_) {
      return { soldLunchQty:0, lunchSalesEur:0, cafeSalesEur:0, cateringOrdersEur:0, themesEur:0, additionalSalesEur:0 };
    }
  }
  function setSales(day, values){ localStorage.setItem(salesKey(day), JSON.stringify(values)); }
  function safeDiv(n,d){ return d > 0 ? n / d : 0; }

  function finalizeDay(day){
    day.sales = getSales(day);
    day.soldLunchQty = day.sales.soldLunchQty || day.soldLunchQty || 0;
    day.lunchSalesEur = day.sales.lunchSalesEur || 0;
    day.cafeSalesEur = day.sales.cafeSalesEur || 0;
    day.cateringOrdersEur = day.sales.cateringOrdersEur || 0;
    day.themesEur = day.sales.themesEur || 0;
    day.additionalSalesEur = day.sales.additionalSalesEur || 0;
    day.totalSalesEur = day.lunchSalesEur + day.cafeSalesEur + day.cateringOrdersEur + day.themesEur + day.additionalSalesEur;

    day.menus.forEach(menu => {
      menu.plannedWeight = menu.components.reduce((sum,c) => sum + c.weightPerPort * c.plannedQty, 0);
      menu.producedWeight = menu.components.reduce((sum,c) => sum + c.weightPerPort * c.producedQty, 0);
      menu.plannedCostTotal = menu.components.length ? menu.components.reduce((sum,c) => sum + c.plannedCost, 0) : menu.plannedCost;
      menu.producedCostTotal = menu.components.length ? menu.components.reduce((sum,c) => sum + c.producedCost, 0) : menu.producedCost;
      menu.hasValues = (
        menu.plannedQty > 0 || menu.producedQty > 0 ||
        menu.plannedWeight > 0 || menu.producedWeight > 0 ||
        menu.plannedCostTotal > 0 || menu.producedCostTotal > 0
      );
    });

    const includedMenus = day.menus.filter(m => m.hasValues && !low(m.menuName).includes('leipäpöytä') && !low(m.menuName).includes('bread table'));
    day.includedMenus = includedMenus;
    day.displayMenus = day.menus.filter(m => m.hasValues);
    day.breadPlannedQty = day.breadMenu ? day.breadMenu.plannedQty : 0;
    day.breadProducedQty = day.breadMenu ? day.breadMenu.producedQty : 0;
    day.totalPlannedWeight = includedMenus.reduce((sum,m) => sum + m.plannedWeight, 0);
    day.totalProducedWeight = includedMenus.reduce((sum,m) => sum + m.producedWeight, 0);
    day.totalPlannedQty = day.breadPlannedQty;
    day.totalProducedQty = day.breadProducedQty;
    day.totalPlannedCost = includedMenus.reduce((sum,m) => sum + m.plannedCostTotal, 0);
    day.totalProducedCost = includedMenus.reduce((sum,m) => sum + m.producedCostTotal, 0);
    day.plannedPerBread = safeDiv(day.totalPlannedWeight, day.breadPlannedQty);
    day.producedPerBread = safeDiv(day.totalProducedWeight, day.breadProducedQty);
    day.plannedCostPerBread = safeDiv(day.totalPlannedCost, day.breadPlannedQty);
    day.producedCostPerBread = safeDiv(day.totalProducedCost, day.breadProducedQty);
    day.costPerPlannedPortion = safeDiv(day.totalPlannedCost, day.totalPlannedQty);
    day.costPerProducedPortion = safeDiv(day.totalProducedCost, day.totalProducedQty);
    day.costPerSoldPortion = safeDiv(day.totalProducedCost, day.soldLunchQty);
    day.wasteQty = Math.max(0, day.totalProducedQty - day.soldLunchQty);
    day.wastePerSoldPortion = safeDiv(day.wasteQty, day.soldLunchQty);
    day.dayWasteCost = day.wasteQty * day.costPerProducedPortion;

    day.displayMenus.forEach(menu => {
      menu.producedServingSize = safeDiv(menu.producedWeight, day.breadProducedQty);
      menu.costPerPlannedPortion = safeDiv(menu.plannedCostTotal, menu.plannedQty);
      menu.costPerProducedPortion = safeDiv(menu.producedCostTotal, menu.producedQty);
      menu.costPerSoldPortion = safeDiv(menu.producedCostTotal, day.soldLunchQty);
      menu.producedCostPerBread = safeDiv(menu.producedCostTotal, day.breadProducedQty);
      menu.components.forEach(c => {
        c.plannedWeight = c.weightPerPort * c.plannedQty;
        c.producedWeight = c.weightPerPort * c.producedQty;
        c.producedServingSize = safeDiv(c.producedWeight, day.breadProducedQty);
        c.costPerPlannedPortion = safeDiv(c.plannedCost, c.plannedQty);
        c.costPerProducedPortion = safeDiv(c.producedCost, c.producedQty);
        c.costPerSoldPortion = safeDiv(c.producedCost, day.soldLunchQty);
        c.producedCostPerBread = safeDiv(c.producedCost, day.breadProducedQty);
      });
    });

    day.hasDetail = day.displayMenus.some(m => m.components && m.components.length);
  }

  function parseDetailedSheet(rows, decimalMode){
    const days = [];
    let currentDay = null, currentMenu = null, insideComponents = false;
    for (let i=0;i<rows.length;i++){
      const row = rows[i];
      if (isDateRow(row)) {
        currentDay = {
          index: days.length + 1,
          dateRaw: normalizeText(row[0]),
          dateDisplay: toDisplayDate(row[0]),
          template: normalizeText(row[1]),
          plannedQtyTemplate: parseNumber(row[3], decimalMode),
          producedQtyTemplate: parseNumber(row[5], decimalMode),
          soldQtyTemplate: parseNumber(row[7], decimalMode),
          menus: [], breadMenu: null
        };
        days.push(currentDay); currentMenu = null; insideComponents = false; continue;
      }
      if (!currentDay) continue;
      if (isMenuHeaderRow(row)) { currentMenu = null; insideComponents = false; continue; }
      if (isModeMarkerRow(row)) continue;
      if (isComponentHeaderRow(row)) { insideComponents = true; continue; }
      if (isMenuRow(row)) {
        currentMenu = {
          menuName: normalizeText(row[1]),
          plannedQty: parseNumber(row[3], decimalMode),
          plannedCost: parseNumber(row[4], decimalMode),
          producedQty: parseNumber(row[5], decimalMode),
          producedCost: parseNumber(row[6], decimalMode),
          components: []
        };
        currentDay.menus.push(currentMenu);
        insideComponents = false;
        const l = low(currentMenu.menuName);
        if (l.includes('leipäpöytä') || l.includes('bread table')) currentDay.breadMenu = currentMenu;
        continue;
      }
      if (insideComponents && currentMenu && isComponentRow(row)) {
        currentMenu.components.push({
          componentName: normalizeText(row[1]),
          weightPerPort: parseNumber(row[2], decimalMode),
          plannedQty: parseNumber(row[3], decimalMode),
          plannedCost: parseNumber(row[4], decimalMode),
          producedQty: parseNumber(row[5], decimalMode),
          producedCost: parseNumber(row[6], decimalMode)
        });
      }
    }
    days.forEach(finalizeDay);
    return buildOverall(days, 'detail');
  }

  function findHeaderRow(rows){
    for (let i=0;i<rows.length;i++){
      const r = rows[i].map(v=>low(v));
      if (r.includes('pvm') || r.includes('date')) return i;
    }
    return -1;
  }
  function indexMap(row){
    const map = {};
    row.forEach((v,i) => {
      const s = low(v);
      if (!s) return;
      map[s] = i;
    });
    return map;
  }
  function idxByContains(row, terms){
    const lows = row.map(v=>low(v));
    for (let i=0;i<lows.length;i++){
      if (terms.some(t => lows[i].includes(t))) return i;
    }
    return -1;
  }
  function parseSummarySheet(rows, decimalMode){
    const hdr = findHeaderRow(rows);
    const days = [];
    if (hdr === -1) return buildOverall(days, 'summary');
    const row = rows[hdr];
    const pvmIdx = idxByContains(row, ['pvm','date']);
    const tplIdx = idxByContains(row, ['suunnitelmapohja','mp template']);
    const plannedQtyIdx = idxByContains(row, ['käyttöpa']) >=0 ? row.findIndex((v,i)=> low(v).includes('käyttöpa') && i>=3) : 3;
    const plannedCostIdx = idxByContains(row, ['kust. yht.']) >=0 ? row.findIndex((v,i)=> low(v).includes('kust. yht.') && i>plannedQtyIdx) : 4;
    // produced qty/cost often next pair
    let producedQtyIdx = -1, producedCostIdx = -1, soldQtyIdx = -1, soldCostIdx = -1;
    for (let i=0;i<row.length;i++){
      const s = low(row[i]);
      if (s.includes('käyttöpa') || s === 'qty') {
        if (i !== plannedQtyIdx && producedQtyIdx === -1) producedQtyIdx = i;
        else if (i !== plannedQtyIdx && i !== producedQtyIdx && soldQtyIdx === -1) soldQtyIdx = i;
      }
      if (s.includes('kust. yht.') || s.includes('cos total')) {
        if (i !== plannedCostIdx && producedCostIdx === -1) producedCostIdx = i;
        else if (i !== plannedCostIdx && i !== producedCostIdx && soldCostIdx === -1) soldCostIdx = i;
      }
    }
    for (let i=hdr+1;i<rows.length;i++){
      const r = rows[i];
      const first = r[pvmIdx];
      if (!((typeof first === 'number' && first > 40000 && first < 60000) || looksLikeDateString(first))) continue;
      const day = {
        index: days.length + 1,
        dateRaw: normalizeText(first),
        dateDisplay: toDisplayDate(first),
        template: normalizeText(r[tplIdx]),
        plannedQtyTemplate: parseNumber(r[plannedQtyIdx], decimalMode),
        producedQtyTemplate: parseNumber(r[producedQtyIdx], decimalMode),
        soldQtyTemplate: parseNumber(r[soldQtyIdx], decimalMode),
        menus: [],
        breadMenu: null
      };
      day.soldLunchQty = day.soldQtyTemplate || 0;
      day.menus = [];
      day.displayMenus = [];
      day.includedMenus = [];
      day.totalPlannedQty = day.plannedQtyTemplate || 0;
      day.totalProducedQty = day.producedQtyTemplate || 0;
      day.totalPlannedCost = parseNumber(r[plannedCostIdx], decimalMode);
      day.totalProducedCost = parseNumber(r[producedCostIdx], decimalMode) || day.totalPlannedCost;
      day.totalPlannedWeight = 0;
      day.totalProducedWeight = 0;
      day.breadPlannedQty = day.plannedQtyTemplate || 0;
      day.breadProducedQty = day.producedQtyTemplate || 0;
      day.plannedPerBread = 0;
      day.producedPerBread = 0;
      day.plannedCostPerBread = safeDiv(day.totalPlannedCost, day.breadPlannedQty);
      day.producedCostPerBread = safeDiv(day.totalProducedCost, day.breadProducedQty);
      day.costPerPlannedPortion = safeDiv(day.totalPlannedCost, day.totalPlannedQty);
      day.costPerProducedPortion = safeDiv(day.totalProducedCost, day.totalProducedQty);
      day.costPerSoldPortion = safeDiv(day.totalProducedCost, day.soldLunchQty);
      day.hasDetail = false;
      finalizeSalesOnly(day);
      days.push(day);
    }
    return buildOverall(days, 'summary');
  }

  function finalizeSalesOnly(day){
    day.sales = getSales(day);
    if (!day.soldLunchQty) day.soldLunchQty = day.sales.soldLunchQty || 0;
    day.lunchSalesEur = day.sales.lunchSalesEur || 0;
    day.cafeSalesEur = day.sales.cafeSalesEur || 0;
    day.cateringOrdersEur = day.sales.cateringOrdersEur || 0;
    day.themesEur = day.sales.themesEur || 0;
    day.additionalSalesEur = day.sales.additionalSalesEur || 0;
    day.totalSalesEur = day.lunchSalesEur + day.cafeSalesEur + day.cateringOrdersEur + day.themesEur + day.additionalSalesEur;
    day.costPerSoldPortion = safeDiv(day.totalProducedCost, day.soldLunchQty);
    day.wasteQty = Math.max(0, day.totalProducedQty - day.soldLunchQty);
    day.wastePerSoldPortion = safeDiv(day.wasteQty, day.soldLunchQty);
    day.dayWasteCost = day.wasteQty * day.costPerProducedPortion;
  }

  function buildOverall(days, sourceType){
    const nonzeroPlanned = days.filter(d => d.costPerPlannedPortion > 0);
    const nonzeroProduced = days.filter(d => d.costPerProducedPortion > 0);
    const nonzeroSold = days.filter(d => d.costPerSoldPortion > 0);
    const overall = {
      sourceType,
      totalPlannedWeight: days.reduce((s,d) => s + (d.totalPlannedWeight || 0), 0),
      totalProducedWeight: days.reduce((s,d) => s + (d.totalProducedWeight || 0), 0),
      totalPlannedCost: days.reduce((s,d) => s + (d.totalPlannedCost || 0), 0),
      totalProducedCost: days.reduce((s,d) => s + (d.totalProducedCost || 0), 0),
      totalPlannedQty: days.reduce((s,d) => s + (d.totalPlannedQty || 0), 0),
      totalProducedQty: days.reduce((s,d) => s + (d.totalProducedQty || 0), 0),
      totalSoldLunchQty: days.reduce((s,d) => s + (d.soldLunchQty || 0), 0),
      daysCount: days.length,
      menusCount: days.reduce((s,d) => s + ((d.includedMenus || []).length), 0),
      componentsCount: days.reduce((s,d) => s + ((d.includedMenus || []).reduce((ss,m) => ss + (m.components ? m.components.length : 0), 0)), 0),
      avgCostPerPlannedPortion: nonzeroPlanned.length ? nonzeroPlanned.reduce((s,d)=>s+d.costPerPlannedPortion,0)/nonzeroPlanned.length : 0,
      avgCostPerProducedPortion: nonzeroProduced.length ? nonzeroProduced.reduce((s,d)=>s+d.costPerProducedPortion,0)/nonzeroProduced.length : 0,
      avgCostPerSoldPortion: nonzeroSold.length ? nonzeroSold.reduce((s,d)=>s+d.costPerSoldPortion,0)/nonzeroSold.length : 0
    };
    return { days, overall };
  }

  function parseSheet(rows, decimalMode){
    const sourceType = detectSourceType(rows);
    state.sourceType = sourceType;
    return sourceType === 'detail' ? parseDetailedSheet(rows, decimalMode) : parseSummarySheet(rows, decimalMode);
  }

  function fmt(value, digits=2){ return new Intl.NumberFormat('fi-FI', { minimumFractionDigits:digits, maximumFractionDigits:digits }).format(value || 0); }
  function fmtQty(value){ return new Intl.NumberFormat('fi-FI', { maximumFractionDigits:0 }).format(value || 0); }
  function escapeHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function exportBasicExcel(){
    if (!state.parsed) { showError('Lue ensin Excel ennen vientiä.'); return; }
    clearError();
    const dayRows = state.parsed.days.map(day => ({
      'Päivä': day.dateDisplay,
      'Pohja': day.template,
      'Suunniteltu määrä': day.totalPlannedQty || 0,
      'Tuotettu määrä': day.totalProducedQty || 0,
      'Myydyt lounaat': day.soldLunchQty || 0,
      'Lounasmyynnit EUR': day.lunchSalesEur || 0,
      'Kahvilamyynnit EUR': day.cafeSalesEur || 0,
      'Tarjoilutilaukset EUR': day.cateringOrdersEur || 0,
      'Teemat EUR': day.themesEur || 0,
      'Lisämyynti EUR': day.additionalSalesEur || 0
    }));

    const wb = XLSX.utils.book_new();
    const ws1 = XLSX.utils.json_to_sheet(dayRows);
    ws1['!cols'] = [
      {wch:14},{wch:24},{wch:16},{wch:16},{wch:16},
      {wch:18},{wch:18},{wch:22},{wch:14},{wch:16}
    ];
    XLSX.utils.book_append_sheet(wb, ws1, 'Paivayhteenveto');
    const base = (el('fileInput').files[0]?.name || 'jalkilaskiainenbasic').replace(/\.[^.]+$/, '');
    XLSX.writeFile(wb, `${base}_basic_yhteenveto.xlsx`);
    showInfo(`Excel viety: ${dayRows.length} päiväkohtaista riviä.`);
  }

