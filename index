  }

  function bindDayInteractions(){
    el('days').querySelectorAll('[data-action="toggle"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const day = btn.closest('.day');
        day.classList.toggle('open');
        btn.textContent = day.classList.contains('open') ? '−' : '+';
      });
    });

    const applySalesChange = (daykey) => {
      const inputs = [...el('days').querySelectorAll('.day-sales input')].filter(inp => inp.dataset.daykey === daykey);
      const values = { soldLunchQty:0, lunchSalesEur:0, cafeSalesEur:0, cateringOrdersEur:0, themesEur:0, additionalSalesEur:0 };
      inputs.forEach(inp => values[inp.dataset.field] = Math.max(0, Number(inp.value) || 0));
      if (!state.parsed) return;
      const day = state.parsed.days.find(d => salesKey(d) === daykey);
      if (day) setSales(day, values);
      state.parsed = parseSheet(state.workbookData, el('decimalMode').value);
      renderSummary(state.parsed);
      renderDays(state.parsed);
      bindDayInteractions();
    };

    el('days').querySelectorAll('[data-action="sales"]').forEach(inp => {
      inp.addEventListener('change', () => applySalesChange(inp.dataset.daykey));
    });
  }

  function loadWorkbook(file){
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type:'array', cellDates:true });
          resolve(workbook);
        } catch(err){ reject(err); }
      };
      reader.onerror = reject;
      reader.readAsArrayBuffer(file);
    });
  }

  async function parseCurrentFile(){
    clearError(); clearInfo();
    const file = el('fileInput').files[0];
    if (!file) { showError('Valitse ensin Excel-tiedosto.'); return; }
    try {
      const workbook = await loadWorkbook(file);
      const sheetName = workbook.SheetNames[0];
      const rows = XLSX.utils.sheet_to_json(workbook.Sheets[sheetName], { header:1, defval:'', raw:true });
      const parsed = parseSheet(rows, el('decimalMode').value);
      if (!parsed.days.length) {
        showError('Excelistä ei löytynyt päiväblokkeja. Tarkista tiedoston rakenne.');
        return;
      }
      state.workbookData = rows;
      state.parsed = parsed;
      renderSummary(parsed);
      renderDayFilter(parsed.days);
      renderDays(parsed);
      bindDayInteractions();
      el('exportBtn').disabled = false;
      showInfo(`Excel luettu: ${parsed.overall.daysCount} päivää. Lähdetyyppi: ${parsed.overall.sourceType === 'detail' ? 'komponenttidata' : 'päiväyhteenveto'}.`);
    } catch(err){
      console.error(err);
      showError('Excelin luku epäonnistui. ' + (err && err.message ? err.message : err));
    }
  }

  el('parseBtn').addEventListener('click', parseCurrentFile);
  el('exportBtn').addEventListener('click', exportBasicExcel);
  el('dayFilter').addEventListener('change', () => {
    if (!state.parsed) return;
    renderDays(state.parsed);
    bindDayInteractions();
  });
})();
</script>
